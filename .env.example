# =========================================================================
# GravitoWear Environment Variable Template (Production Configuration)
# =========================================================================
# Copy this file to `.env.local` for local development.
# Define these environment variables in your Vercel Project Dashboard.

# MongoDB Atlas Connection URI
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/gravitowear?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_connection_string_here

# Secret phrase used to sign JWT session cookies
# Can be generated using: openssl rand -base64 32
JWT_SECRET=your_jwt_signing_secret_here

# NextAuth Config (Required if next-auth is enabled, or fallback secrets)
NEXTAUTH_SECRET=your_nextauth_signing_secret_here

# NextAuth URL (Set to http://localhost:3000 for local dev or production URL for Vercel)
# Example: https://gravitowear.vercel.app
NEXTAUTH_URL=http://localhost:3000
